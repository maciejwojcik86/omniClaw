  "hardware": {
    "enabled": false,
    "transport": "none",
    "serial_port": null,
    "baud_rate": 115200,
    "probe_target": null,
    "workspace_datasheets": false
  },
  "session": {
    "dm_scope": "per_channel_peer",
    "idle_minutes": 60,
    "identity_links": [],
    "typing_interval_secs": 5
  }
}
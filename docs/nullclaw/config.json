{
  "default_temperature": 0.7,
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.3-codex"
      }
    }
  },
  "diagnostics": {
    "backend": "jsonl",
    "log_tool_calls": true,
    "log_message_receipts": true,
    "log_message_payloads": true,
    "log_llm_io": true
  },
  "autonomy": {
    "level": "supervised",
    "workspace_only": true,
    "max_actions_per_hour": 20,
    "require_approval_for_medium_risk": false,
    "block_high_risk_commands": true,
    "allowed_commands": [
      "python3",
      "python",
      "ls",
      "cat",
      "cp",
      "mv",
      "mkdir",
      "rm",
      "find",
      "sed",
      "awk",
      "grep",
      "head",
      "tail",
      "date",
      "basename"
    ],
    "allowed_paths": [
      "/home/agent_director_01/.nullclaw/workspace"
    ]
  },
  "runtime": {
    "kind": "native",
    "docker": {
      "image": "alpine:3.20",
      "network": "none",
      "memory_limit_mb": 512,
      "read_only_rootfs": true,
      "mount_workspace": true
    }
  },
  "reliability": {
    "provider_retries": 2,
    "provider_backoff_ms": 500,
    "channel_initial_backoff_secs": 2,
    "channel_max_backoff_secs": 60,
    "scheduler_poll_secs": 15,
    "scheduler_retries": 2,
    "fallback_providers": [],
    "api_keys": [],
    "model_fallbacks": []
  },
  "scheduler": {
    "enabled": true,
    "max_tasks": 64,
    "max_concurrent": 4
  },
  "agent": {
    "compact_context": false,
    "max_tool_iterations": 25,
    "max_history_messages": 50,
    "parallel_tools": false,
    "tool_dispatcher": "auto",
    "session_idle_timeout_secs": 1800,
    "compaction_keep_recent": 20,
    "compaction_max_summary_chars": 2000,
    "compaction_max_source_chars": 12000,
    "message_timeout_secs": 300
  },
  "channels": {
    "telegram": {
      "accounts": {
        "main": {
          "bot_token": "8209596557:AAGgu85J-3sugvKRZ0Vnn1n9VlaVrtDBsuE",
          "allow_from": [
            "*"
          ],
          "reply_in_private": true
        }
      }
    }
  },
  "memory": {
    "profile": "markdown_only",
    "backend": "markdown",
    "auto_save": true,
    "citations": "auto",
    "search": {
      "enabled": true,
      "provider": "none",
      "model": "text-embedding-3-small",
      "dimensions": 1536,
      "fallback_provider": "none",
      "store": {
        "kind": "auto",
        "sidecar_path": "",
        "qdrant_url": "",
        "qdrant_api_key": "",
        "qdrant_collection": "nullclaw_memories",
        "pgvector_table": "memory_embeddings"
      },
      "chunking": {
        "max_tokens": 512,
        "overlap": 64
      },
      "sync": {
        "mode": "best_effort",
        "embed_timeout_ms": 15000,
        "vector_timeout_ms": 5000,
        "embed_max_retries": 2,
        "vector_max_retries": 2
      },
      "query": {
        "max_results": 6,
        "min_score": 0,
        "merge_strategy": "rrf",
        "rrf_k": 60,
        "hybrid": {
          "enabled": false,
          "vector_weight": 0.7,
          "text_weight": 0.3,
          "candidate_multiplier": 4,
          "mmr": {
            "enabled": false,
            "lambda": 0.7
          },
          "temporal_decay": {
            "enabled": false,
            "half_life_days": 30
          }
        }
      },
      "cache": {
        "enabled": true,
        "max_entries": 10000
      }
    },
    "qmd": {
      "enabled": false,
      "command": "qmd",
      "search_mode": "search",
      "include_default_memory": true,
      "mcporter": {
        "enabled": false,
        "server_name": "qmd",
        "start_daemon": true
      },
      "paths": [],
      "sessions": {
        "enabled": false,
        "export_dir": "",
        "retention_days": 30
      },
      "update": {
        "interval_ms": 300000,
        "debounce_ms": 15000,
        "on_boot": true,
        "wait_for_boot_sync": false,
        "embed_interval_ms": 3600000,
        "command_timeout_ms": 30000,
        "update_timeout_ms": 120000,
        "embed_timeout_ms": 120000
      },
      "limits": {
        "max_results": 6,
        "max_snippet_chars": 700,
        "max_injected_chars": 4000,
        "timeout_ms": 4000
      }
    },
    "lifecycle": {
      "hygiene_enabled": true,
      "archive_after_days": 7,
      "purge_after_days": 30,
      "conversation_retention_days": 30,
      "snapshot_enabled": false,
      "snapshot_on_hygiene": false,
      "auto_hydrate": true
    },
    "response_cache": {
      "enabled": false,
      "ttl_minutes": 60,
      "max_entries": 5000
    },
    "reliability": {
      "rollout_mode": "off",
      "circuit_breaker_failures": 5,
      "circuit_breaker_cooldown_ms": 30000,
      "shadow_hybrid_percent": 0,
      "canary_hybrid_percent": 0,
      "fallback_policy": "degrade"
    },
    "postgres": {
      "url": "",
      "schema": "public",
      "table": "memories",
      "connect_timeout_secs": 30
    },
    "redis": {
      "host": "127.0.0.1",
      "port": 6379,
      "password": "",
      "db_index": 0,
      "key_prefix": "nullclaw",
      "ttl_seconds": 0
    },
    "api": {
      "url": "",
      "api_key": "",
      "timeout_ms": 10000,
      "namespace": ""
    },
    "retrieval_stages": {
      "query_expansion_enabled": false,
      "adaptive_retrieval_enabled": false,
      "adaptive_keyword_max_tokens": 3,
      "adaptive_vector_min_tokens": 6,
      "llm_reranker_enabled": false,
      "llm_reranker_max_candidates": 10,
      "llm_reranker_timeout_ms": 5000
    },
    "summarizer": {
      "enabled": false,
      "window_size_tokens": 4000,
      "summary_max_tokens": 500,
      "auto_extract_semantic": true
    }
  },
  "gateway": {
    "port": 3000,
    "host": "127.0.0.1",
    "require_pairing": true,
    "allow_public_bind": false,
    "pair_rate_limit_per_minute": 10,
    "webhook_rate_limit_per_minute": 60,
    "idempotency_ttl_secs": 300,
    "paired_tokens": []
  },
  "tunnel": {
    "provider": "none"
  },
  "composio": {
    "enabled": false,
    "api_key": null,
    "entity_id": "default"
  },
  "secrets": {
    "encrypt": true
  },
  "browser": {
    "enabled": false,
    "session_name": null,
    "backend": "agent_browser",
    "native_headless": true,
    "native_webdriver_url": "http://127.0.0.1:9515",
    "native_chrome_path": null,
    "allowed_domains": []
  },
  "http_request": {
    "enabled": false,
    "max_response_size": 1000000,
    "timeout_secs": 30
  },
  "identity": {
    "format": "nullclaw",
    "aieos_path": null,
    "aieos_inline": null
  },
  "cost": {
    "enabled": false,
    "daily_limit_usd": 10,
    "monthly_limit_usd": 100,
    "warn_at_percent": 80,
    "allow_override": false
  },
  "security": {
    "sandbox": {
      "enabled": null,
      "backend": "auto"
    },
    "resources": {
      "max_memory_mb": 512,
      "max_cpu_time_seconds": 60,
      "max_subprocesses": 10,
      "memory_monitoring": true
    },
    "audit": {
